{
  "name": "@agent-estate/vscode-extension",
  "version": "0.1.0",
  "private": true,
  "description": "VS Code command surface for Agent Estate audit workflows.",
  "type": "module",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:agentEstate.scanEnvironment",
    "onCommand:agentEstate.openReport",
    "onCommand:agentEstate.exportMarkdownReport"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agentEstate.scanEnvironment",
        "title": "Agent Estate: Scan Environment"
      },
      {
        "command": "agentEstate.openReport",
        "title": "Agent Estate: Open Report"
      },
      {
        "command": "agentEstate.exportMarkdownReport",
        "title": "Agent Estate: Export Markdown Report"
      }
    ]
  },
  "scripts": {
    "check": "node ../../scripts/validate-project.mjs --package @agent-estate/vscode-extension"
  },
  "dependencies": {
    "@agent-estate/collector": "workspace:*",
    "@agent-estate/policy": "workspace:*",
    "@agent-estate/shared": "workspace:*"
  },
  "devDependencies": {}
}
